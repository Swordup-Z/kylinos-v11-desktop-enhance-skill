-class IconItemDelegate : public QStyledItemDelegate
-{
-public:
-    explicit IconItemDelegate(QObject *parent = nullptr)
-        : QStyledItemDelegate(parent)
-    {
-    }
-
-    void paint(QPainter *painter, const QStyleOptionViewItem &option, const QModelIndex &index) const override
-    {
-        painter->save();
-
-        QStyleOptionViewItem opt(option);
-        initStyleOption(&opt, index);
-        opt.icon = QIcon();
-        QStyle *style = opt.widget ? opt.widget->style() : QApplication::style();
-        style->drawControl(QStyle::CE_ItemViewItem, &opt, painter, opt.widget);
-
-        const QRect iconBox(option.rect.left() + 6, option.rect.top() + 3, 26, option.rect.height() - 6);
-        const QIcon icon = index.data(Qt::DecorationRole).value<QIcon>();
-        if (!icon.isNull()) {
-            painter->drawPixmap(iconBox, iconBadgePixmap(icon, iconBox.size()));
-        }
-
-        const bool selected = option.state.testFlag(QStyle::State_Selected);
-        QRect textRect = option.rect.adjusted(40, 0, -6, 0);
-        painter->setPen(selected ? option.palette.highlightedText().color() : option.palette.text().color());
-        painter->drawText(textRect, Qt::AlignVCenter | Qt::AlignLeft, opt.text);
-        painter->restore();
-    }
-};
-
-class IconComboBox : public QComboBox
-{
-public:
-    explicit IconComboBox(QWidget *parent = nullptr)
-        : QComboBox(parent)
-    {
-    }
-
-    void attachLineEditPopup()
-    {
-        if (lineEdit()) {
-            lineEdit()->installEventFilter(this);
-        }
-    }
-
-protected:
-    void showPopup() override
-    {
-        startLoadingAllIconNames();
-        QComboBox::showPopup();
-    }
-
-    bool eventFilter(QObject *watched, QEvent *event) override
-    {
-        if (watched == lineEdit()
-            && (event->type() == QEvent::MouseButtonPress || event->type() == QEvent::FocusIn)) {
-            QTimer::singleShot(0, this, [this]() {
-                showPopup();
-            });
-        }
-        return QComboBox::eventFilter(watched, event);
-    }
-
-private:
-    void startLoadingAllIconNames()
-    {
-        if (m_allIconNamesLoaded || m_loadingAllIconNames) {
-            return;
-        }
-        m_loadingAllIconNames = true;
-
-        QPointer<IconComboBox> combo(this);
-        QThread *worker = QThread::create([combo]() {
-            const QStringList names = availableIconNames();
-            if (!combo) {
-                return;
-            }
-            QMetaObject::invokeMethod(combo.data(), [combo, names]() {
-                if (!combo) {
-                    return;
-                }
-
-                QSet<QString> existing;
-                for (int i = 0; i < combo->count(); ++i) {
-                    existing.insert(combo->itemText(i));
-                }
-
-                combo->m_pendingIconNames.clear();
-                const QString current = combo->currentText();
-                for (const QString &name : names) {
-                    if (!existing.contains(name)) {
-                        combo->m_pendingIconNames << name;
-                    }
-                }
-                combo->setEditText(current);
-                combo->m_allIconNamesLoaded = true;
-                combo->m_loadingAllIconNames = false;
-                combo->appendPendingIconNames();
-            }, Qt::QueuedConnection);
-        });
-        connect(worker, &QThread::finished, worker, &QObject::deleteLater);
-        worker->start();
-    }
-
-    void appendPendingIconNames()
-    {
-        const int chunkSize = 80;
-        const QString current = currentText();
-        for (int i = 0; i < chunkSize && !m_pendingIconNames.isEmpty(); ++i) {
-            const QString name = m_pendingIconNames.takeFirst();
-            addItem(themedIcon(name), name);
-        }
-        setEditText(current);
-        if (!m_pendingIconNames.isEmpty()) {
-            QTimer::singleShot(0, this, [this]() {
-                appendPendingIconNames();
-            });
-        }
-    }
-
-    bool m_allIconNamesLoaded = false;
-    bool m_loadingAllIconNames = false;
-    QStringList m_pendingIconNames;
-};
