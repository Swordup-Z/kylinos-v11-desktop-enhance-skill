+namespace UkuiSearch {
+
+struct CommandSearchEntry
+{
+    QString id;
+    QString name;
+    QString description;
+    QString command;
+    QStringList args;
+    QStringList keywords;
+    QString iconName;
+    QString workingDirectory;
+    QString confirmMessage;
+    bool confirm = false;
+    bool detached = false;
+    bool showInBestMatch = true;
+    int timeout = 30000;
+};
+
+class LIBSEARCH_EXPORT CommandSearchPlugin : public QObject, public SearchPluginIface
+{
+    Q_OBJECT
+public:
+    explicit CommandSearchPlugin(QObject *parent = nullptr);
+    PluginType pluginType() { return PluginType::SearchPlugin; }
+    const QString name();
+    const QString description();
+    const QIcon icon() { return IconLoader::loadIconQt("system-run"); }
+    void setEnable(bool enable) { m_enable = enable; }
+    bool isEnable() { return m_enable; }
+    QString getPluginName();
+
+    size_t KeywordSearch(QString keyword, DataQueue<ResultInfo> *searchResult);
+    void stopSearch();
+    QList<SearchPluginIface::Actioninfo> getActioninfo(int type);
+    void openAction(int actionkey, QString key, int type);
+    QWidget *detailPage(const ResultInfo &ri);
+
+private:
+    static void setAutoTestAttribute(QWidget *widget, const QString &widgetType, const QString &widgetName, const QString &desc);
+    static QString configPath();
+    static bool ensureDefaultConfig();
+    static QList<CommandSearchEntry> loadCommands();
+    static bool matches(const CommandSearchEntry &entry, const QString &keyword);
+    static SearchPluginIface::ResultInfo createResultInfo(const CommandSearchEntry &entry, size_t searchId);
+    bool runCommand(const CommandSearchEntry &entry);
+    void initDetailPage();
+
+    bool m_enable = true;
+    QList<CommandSearchPlugin::Actioninfo> m_actionInfo;
+    static size_t m_uniqueSymbol;
+    static QMutex m_mutex;
+
+    QString m_currentActionKey;
+    QString m_currentDescription;
+    QWidget *m_detailPage = nullptr;
+    QVBoxLayout *m_detailLyt = nullptr;
+    QLabel *m_iconLabel = nullptr;
+    QFrame *m_nameFrame = nullptr;
+    QHBoxLayout *m_nameFrameLyt = nullptr;
+    QLabel *m_nameLabel = nullptr;
+    QLabel *m_pluginLabel = nullptr;
+    SeparationLine *m_line_1 = nullptr;
+    QLabel *m_descLabel = nullptr;
+    QFrame *m_actionFrame = nullptr;
+    QVBoxLayout *m_actionFrameLyt = nullptr;
+    ActionLabel *m_actionLabel1 = nullptr;
+    QIcon m_detailPageIcon;
+};
+
+}
+
+#endif // COMMANDSEARCHPLUGIN_H
