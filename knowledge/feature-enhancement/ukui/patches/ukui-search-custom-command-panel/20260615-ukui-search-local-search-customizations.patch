+size_t CommandSearchPlugin::m_uniqueSymbol = 0;
+QMutex CommandSearchPlugin::m_mutex;
+
+CommandSearchPlugin::CommandSearchPlugin(QObject *parent) : QObject(parent)
+{
+    SearchPluginIface::Actioninfo run { 0, tr("Run") };
+    m_actionInfo << run;
+    initDetailPage();
+}
+
+void CommandSearchPlugin::setAutoTestAttribute(QWidget *widget, const QString &widgetType, const QString &widgetName, const QString &desc)
+{
+    QString name = "ukui-search_CommandSearchPlugin_" + widgetType + "_" + widgetName;
+    widget->setAccessibleName(name);
+    widget->setAccessibleDescription(desc);
+}
+
+const QString CommandSearchPlugin::name()
+{
+    return QStringLiteral("Command Search");
+}
+
+const QString CommandSearchPlugin::description()
+{
+    return tr("Custom command search.");
+}
+
+QString CommandSearchPlugin::getPluginName()
+{
+    return tr("Command Search");
+}
+
+size_t CommandSearchPlugin::KeywordSearch(QString keyword, DataQueue<SearchPluginIface::ResultInfo> *searchResult)
+{
+    m_mutex.lock();
+    ++m_uniqueSymbol;
+    const size_t searchId = m_uniqueSymbol;
+    m_mutex.unlock();
+
+    const QString normalizedKeyword = keyword.trimmed();
+    if (normalizedKeyword.size() < 2) {
+        return searchId;
+    }
+
+    const QList<CommandSearchEntry> entries = loadCommands();
+    for (const CommandSearchEntry &entry : entries) {
+        if (!matches(entry, normalizedKeyword)) {
+            continue;
+        }
+
+        m_mutex.lock();
+        const bool isCurrentSearch = searchId == m_uniqueSymbol;
+        m_mutex.unlock();
+        if (!isCurrentSearch) {
+            return searchId;
+        }
+        searchResult->enqueue(createResultInfo(entry, searchId));
+    }
+
+    return searchId;
+}
+
+void CommandSearchPlugin::stopSearch()
+{
+    m_mutex.lock();
+    ++m_uniqueSymbol;
+    m_mutex.unlock();
+}
+
+QList<SearchPluginIface::Actioninfo> CommandSearchPlugin::getActioninfo(int type)
+{
+    Q_UNUSED(type)
+    return m_actionInfo;
+}
+
+void CommandSearchPlugin::openAction(int actionkey, QString key, int type)
+{
+    Q_UNUSED(type)
+    if (actionkey != 0) {
+        return;
+    }
+
+    const QList<CommandSearchEntry> entries = loadCommands();
+    for (const CommandSearchEntry &entry : entries) {
+        if (entry.id == key) {
+            DataCollecter::collectLaunchEvent(QStringLiteral("commandSearch"), QStringLiteral("run"));
+            runCommand(entry);
+            return;
+        }
+    }
+    qWarning() << "Command Search: unknown command id" << key;
+}
+
+QWidget *CommandSearchPlugin::detailPage(const ResultInfo &ri)
+{
+    m_currentActionKey = ri.actionKey;
+    m_currentDescription = ri.description.isEmpty() ? QString() : ri.description.first().value;
+    m_detailPageIcon = ri.icon;
+    m_iconLabel->setPixmap(m_detailPageIcon.pixmap(120, 120));
+
+    QFontMetrics fontMetrics = m_nameLabel->fontMetrics();
+    QString showName = fontMetrics.elidedText(ri.name, Qt::ElideRight, 215);
+    m_nameLabel->setText(FileUtils::setAllTextBold(showName));
+    m_nameLabel->setToolTip(showName == ri.name ? QString() : ri.name);
+    m_pluginLabel->setText(tr("Command"));
+    m_descLabel->setText(FileUtils::escapeHtml(m_currentDescription));
+    m_actionLabel1->setText(tr("Run"));
+
+    return m_detailPage;
+}
