+QString CommandSearchPlugin::configPath()
+{
+    return QDir::homePath() + QStringLiteral("/.config/org.ukui/ukui-search/custom-commands.json");
+}
+
+namespace {
+
+QString expandUserPathToken(const QString &text)
+{
+    const QString home = QDir::homePath();
+    if (text == QStringLiteral("~")) {
+        return home;
+    }
+    if (text.startsWith(QStringLiteral("~/"))) {
+        return home + text.mid(1);
+    }
+    if (text == QStringLiteral("$HOME")) {
+        return home;
+    }
+    if (text.startsWith(QStringLiteral("$HOME/"))) {
+        return home + text.mid(5);
+    }
+    if (text == QStringLiteral("${HOME}")) {
+        return home;
+    }
+    if (text.startsWith(QStringLiteral("${HOME}/"))) {
+        return home + text.mid(7);
+    }
+    return text;
+}
+
+QStringList expandUserPathTokens(const QStringList &items)
+{
+    QStringList expanded;
+    for (const QString &item : items) {
+        expanded << expandUserPathToken(item);
+    }
+    return expanded;
+}
+
+}
+
+bool CommandSearchPlugin::ensureDefaultConfig()
+{
+    const QString path = configPath();
+    if (QFileInfo::exists(path)) {
+        return true;
+    }
+
+    QDir dir(QFileInfo(path).absolutePath());
+    if (!dir.exists() && !dir.mkpath(QStringLiteral("."))) {
+        qWarning() << "Command Search: failed to create config dir" << dir.absolutePath();
+        return false;
+    }
+
+    QJsonObject emptyTrash {
+        { QStringLiteral("id"), QStringLiteral("empty-trash") },
+        { QStringLiteral("name"), QStringLiteral("清空回收站") },
+        { QStringLiteral("description"), QStringLiteral("永久删除回收站中的所有项目") },
+        { QStringLiteral("keywords"), QJsonArray {
+              QStringLiteral("清空回收站"),
+              QStringLiteral("清理回收站"),
+              QStringLiteral("清除回收站"),
+              QStringLiteral("回收站"),
+              QStringLiteral("垃圾桶"),
+              QStringLiteral("empty trash"),
+              QStringLiteral("clear trash"),
+              QStringLiteral("trash"),
+              QStringLiteral("recycle bin")
+          } },
+        { QStringLiteral("command"), QStringLiteral("gio") },
+        { QStringLiteral("args"), QJsonArray { QStringLiteral("trash"), QStringLiteral("--empty") } },
+        { QStringLiteral("icon"), QStringLiteral("user-trash") },
+        { QStringLiteral("confirm"), true },
+        { QStringLiteral("confirmMessage"), QStringLiteral("是否永久删除回收站中的所有项目？") },
+        { QStringLiteral("detached"), false },
+        { QStringLiteral("showInBestMatch"), true },
+        { QStringLiteral("timeout"), 30000 }
+    };
+
+    QJsonObject root {
+        { QStringLiteral("version"), 1 },
+        { QStringLiteral("commands"), QJsonArray { emptyTrash } }
+    };
+
+    QFile file(path);
+    if (!file.open(QIODevice::WriteOnly | QIODevice::Truncate | QIODevice::Text)) {
+        qWarning() << "Command Search: failed to create config" << path;
+        return false;
+    }
+    file.write(QJsonDocument(root).toJson(QJsonDocument::Indented));
+    return true;
+}
+
+QList<CommandSearchEntry> CommandSearchPlugin::loadCommands()
+{
+    QList<CommandSearchEntry> entries;
+    if (!ensureDefaultConfig()) {
+        return entries;
+    }
+
+    QFile file(configPath());
+    if (!file.open(QIODevice::ReadOnly | QIODevice::Text)) {
+        qWarning() << "Command Search: failed to open config" << configPath();
+        return entries;
+    }
+
+    QJsonParseError parseError;
+    const QJsonDocument doc = QJsonDocument::fromJson(file.readAll(), &parseError);
+    if (parseError.error != QJsonParseError::NoError || !doc.isObject()) {
+        qWarning() << "Command Search: invalid config" << parseError.errorString();
+        return entries;
+    }
+
+    const QJsonArray commands = doc.object().value(QStringLiteral("commands")).toArray();
+    for (const QJsonValue &value : commands) {
+        if (!value.isObject()) {
+            continue;
+        }
+
+        const QJsonObject object = value.toObject();
+        CommandSearchEntry entry;
+        entry.id = object.value(QStringLiteral("id")).toString();
+        entry.name = object.value(QStringLiteral("name")).toString();
+        entry.description = object.value(QStringLiteral("description")).toString();
+        entry.command = object.value(QStringLiteral("command")).toString();
+        entry.iconName = object.value(QStringLiteral("icon")).toString(QStringLiteral("system-run"));
+        entry.workingDirectory = object.value(QStringLiteral("workingDirectory")).toString();
+        entry.confirmMessage = object.value(QStringLiteral("confirmMessage")).toString();
+        entry.confirm = object.value(QStringLiteral("confirm")).toBool(false);
+        entry.detached = object.value(QStringLiteral("detached")).toBool(false);
+        entry.showInBestMatch = object.value(QStringLiteral("showInBestMatch")).toBool(true);
+        entry.timeout = object.value(QStringLiteral("timeout")).toInt(30000);
+
+        const QJsonArray args = object.value(QStringLiteral("args")).toArray();
+        for (const QJsonValue &arg : args) {
+            entry.args << arg.toString();
+        }
+
+        const QJsonArray keywords = object.value(QStringLiteral("keywords")).toArray();
+        for (const QJsonValue &keyword : keywords) {
+            const QString text = keyword.toString().trimmed();
+            if (!text.isEmpty()) {
+                entry.keywords << text;
+            }
+        }
+
+        if (entry.id.isEmpty() || entry.name.isEmpty() || entry.command.isEmpty()) {
+            qWarning() << "Command Search: skip incomplete command" << entry.id << entry.name << entry.command;
+            continue;
+        }
+        if (!entry.keywords.contains(entry.name, Qt::CaseInsensitive)) {
+            entry.keywords.prepend(entry.name);
+        }
+        entries << entry;
+    }
+
+    return entries;
+}
+
+bool CommandSearchPlugin::matches(const CommandSearchEntry &entry, const QString &keyword)
+{
+    for (const QString &alias : entry.keywords) {
+        if (alias.contains(keyword, Qt::CaseInsensitive)
+            || keyword.contains(alias, Qt::CaseInsensitive)) {
+            return true;
+        }
+    }
+    return false;
+}
+
+SearchPluginIface::ResultInfo CommandSearchPlugin::createResultInfo(const CommandSearchEntry &entry, size_t searchId)
+{
+    SearchPluginIface::DescriptionInfo description;
+    description.key = QObject::tr("Description:");
+    description.value = entry.description;
+
+    SearchPluginIface::ResultInfo resultInfo;
+    resultInfo.name = entry.name;
+    resultInfo.toolTip = entry.description.isEmpty() ? entry.name : entry.description;
+    resultInfo.description.append(description);
+    resultInfo.resourceType = QStringLiteral("command");
+    resultInfo.iconName = entry.iconName;
+    resultInfo.icon = IconLoader::loadIconXdg(entry.iconName, IconLoader::loadIconQt(entry.iconName));
+    resultInfo.actionKey = entry.id;
+    resultInfo.type = 0;
+    resultInfo.showInBestMatch = entry.showInBestMatch;
+    resultInfo.searchID = searchId;
+    return resultInfo;
+}
+
+bool CommandSearchPlugin::runCommand(const CommandSearchEntry &entry)
+{
+    if (entry.confirm) {
+        QMessageBox msgBox(m_detailPage);
+        const auto cancelButton = msgBox.addButton(tr("Cancel"), QMessageBox::RejectRole);
+        const auto confirmButton = msgBox.addButton(tr("Run"), QMessageBox::AcceptRole);
+        setAutoTestAttribute(confirmButton, "QPushButton", "runCommandConfirmButton", "the confirm button for running command");
+        setAutoTestAttribute(cancelButton, "QPushButton", "runCommandCancelButton", "the cancel button for running command");
+        msgBox.setIcon(QMessageBox::Warning);
+        msgBox.setWindowTitle(entry.name);
+        msgBox.setText(entry.confirmMessage.isEmpty() ? tr("Run this command?") : entry.confirmMessage);
+        msgBox.exec();
+        if (msgBox.clickedButton() != confirmButton) {
+            return false;
+        }
+    }
+
+    const QString command = expandUserPathToken(entry.command);
+    const QStringList args = expandUserPathTokens(entry.args);
+    const QString workingDirectory = expandUserPathToken(entry.workingDirectory);
+
+    if (entry.detached) {
+        bool started(false);
+        if (workingDirectory.isEmpty()) {
+            started = QProcess::startDetached(command, args);
+        } else {
+            started = QProcess::startDetached(command, args, workingDirectory);
+        }
+        if (!started) {
+            QMessageBox::warning(m_detailPage, entry.name, tr("Failed to start command."));
+        }
+        return started;
+    }
+
+    QProcess process;
+    if (!workingDirectory.isEmpty()) {
+        process.setWorkingDirectory(workingDirectory);
+    }
+    process.start(command, args);
+    if (!process.waitForStarted(5000)) {
+        QMessageBox::warning(m_detailPage, entry.name, tr("Failed to start command."));
+        return false;
+    }
+
+    const int timeout = entry.timeout > 0 ? entry.timeout : 30000;
+    if (!process.waitForFinished(timeout)) {
+        process.kill();
+        process.waitForFinished();
+        QMessageBox::warning(m_detailPage, entry.name, tr("Command timed out."));
+        return false;
+    }
+
+    if (process.exitStatus() != QProcess::NormalExit || process.exitCode() != 0) {
+        QMessageBox::warning(m_detailPage, entry.name, tr("Command failed."));
+        return false;
+    }
+    return true;
+}
+
+void CommandSearchPlugin::initDetailPage()
+{
+    m_detailPage = new QWidget();
+    m_detailPage->setFixedWidth(360);
+    m_detailPage->setAttribute(Qt::WA_TranslucentBackground);
+    m_detailLyt = new QVBoxLayout(m_detailPage);
+    m_detailLyt->setContentsMargins(8, 0, 16, 0);
+    m_iconLabel = new QLabel(m_detailPage);
+    m_iconLabel->setAlignment(Qt::AlignCenter);
+    m_iconLabel->setFixedHeight(128);
+
+    m_nameFrame = new QFrame(m_detailPage);
+    m_nameFrameLyt = new QHBoxLayout(m_nameFrame);
+    m_nameFrame->setLayout(m_nameFrameLyt);
+    m_nameFrameLyt->setContentsMargins(8, 0, 0, 0);
+    m_nameLabel = new QLabel(m_nameFrame);
+    setAutoTestAttribute(m_nameLabel, "QLabel", "nameLabel", "the label shows command name");
+    m_nameLabel->setMaximumWidth(280);
+    m_pluginLabel = new QLabel(m_nameFrame);
+    m_pluginLabel->setText(tr("Command"));
+    m_pluginLabel->setEnabled(false);
+    m_nameFrameLyt->addWidget(m_nameLabel);
+    m_nameFrameLyt->addStretch();
+    m_nameFrameLyt->addWidget(m_pluginLabel);
+
+    m_line_1 = new SeparationLine(m_detailPage);
+    m_descLabel = new QLabel(m_detailPage);
+    setAutoTestAttribute(m_descLabel, "QLabel", "descLabel", "the label shows command description");
+    m_descLabel->setTextFormat(Qt::PlainText);
+    m_descLabel->setWordWrap(true);
+    m_descLabel->setContentsMargins(8, 0, 8, 0);
+
+    m_actionFrame = new QFrame(m_detailPage);
+    m_actionFrameLyt = new QVBoxLayout(m_actionFrame);
+    m_actionFrameLyt->setContentsMargins(8, 0, 0, 0);
+    m_actionLabel1 = new ActionLabel(tr("Run"), m_currentActionKey, m_actionFrame);
+    setAutoTestAttribute(m_actionLabel1, "ActionLabel", "actionLabel1", "the label of run command action");
+    m_actionFrameLyt->addWidget(m_actionLabel1);
+    m_actionFrame->setLayout(m_actionFrameLyt);
+
+    m_detailLyt->addSpacing(50);
+    m_detailLyt->addWidget(m_iconLabel);
+    m_detailLyt->addWidget(m_nameFrame);
+    m_detailLyt->addWidget(m_line_1);
+    m_detailLyt->addWidget(m_descLabel);
+    m_detailLyt->addWidget(m_actionFrame);
+    m_detailLyt->addStretch();
+    m_detailPage->setLayout(m_detailLyt);
+
+    connect(m_actionLabel1, &ActionLabel::actionTriggered, [ & ](){
+        openAction(0, m_currentActionKey, 0);
+    });
+}
