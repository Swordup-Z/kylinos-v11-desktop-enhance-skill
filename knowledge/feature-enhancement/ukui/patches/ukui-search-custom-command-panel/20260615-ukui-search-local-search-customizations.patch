+QStringList jsonArrayToStringList(const QJsonArray &array)
+{
+    QStringList list;
+    for (const QJsonValue &value : array) {
+        const QString text = value.toString().trimmed();
+        if (!text.isEmpty()) {
+            list << text;
+        }
+    }
+    return list;
+}
+
+QJsonArray stringListToJsonArray(const QStringList &list)
+{
+    QJsonArray array;
+    for (const QString &item : list) {
+        const QString text = item.trimmed();
+        if (!text.isEmpty()) {
+            array.append(text);
+        }
+    }
+    return array;
+}
+
+QStringList plainTextToList(QPlainTextEdit *editor)
+{
+    return editor->toPlainText().split(QLatin1Char('\n'), Qt::SkipEmptyParts);
+}
