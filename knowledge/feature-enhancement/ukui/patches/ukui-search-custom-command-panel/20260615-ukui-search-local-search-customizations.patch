+
+    void loadConfig()
+    {
+        m_root = QJsonObject {
+            { QStringLiteral("version"), 1 },
+            { QStringLiteral("commands"), QJsonArray { defaultEmptyTrashCommand() } }
+        };
+
+        QFile file(commandConfigPath());
+        if (file.exists()) {
+            if (!file.open(QIODevice::ReadOnly | QIODevice::Text)) {
+                QMessageBox::warning(this, QObject::tr("Custom commands"), QObject::tr("Failed to open command configuration."));
+            } else {
+                QJsonParseError parseError;
+                const QJsonDocument doc = QJsonDocument::fromJson(file.readAll(), &parseError);
+                if (parseError.error == QJsonParseError::NoError && doc.isObject()) {
+                    m_root = doc.object();
+                } else {
+                    QMessageBox::warning(this, QObject::tr("Custom commands"), QObject::tr("Command configuration is not valid JSON. Saving will replace it."));
+                }
+            }
+        }
+
+        m_commands.clear();
+        const QJsonArray commands = m_root.value(QStringLiteral("commands")).toArray();
+        for (const QJsonValue &value : commands) {
+            if (value.isObject()) {
+                m_commands.append(value.toObject());
+            }
+        }
+        if (m_commands.isEmpty()) {
+            m_commands.append(defaultEmptyTrashCommand());
+        }
+        refreshList();
+        m_commandList->setCurrentRow(0);
+    }
+
+    void refreshList()
+    {
+        const int currentRow = m_commandList->currentRow();
+        m_commandList->blockSignals(true);
+        m_commandList->clear();
+        for (const QJsonObject &command : m_commands) {
+            const QString name = command.value(QStringLiteral("name")).toString();
+            const QString id = command.value(QStringLiteral("id")).toString();
+            m_commandList->addItem(name.isEmpty() ? id : name);
+        }
+        m_commandList->blockSignals(false);
+        if (!m_commands.isEmpty()) {
+            m_commandList->setCurrentRow(qBound(0, currentRow, m_commands.size() - 1));
+        } else {
+            loadCommandToEditor(-1);
+        }
+    }
+
+    void loadCommandToEditor(int row)
+    {
+        m_currentRow = row;
+        const bool enabled = row >= 0 && row < m_commands.size();
+        setEditorEnabled(enabled);
+        m_loading = true;
+        if (!enabled) {
+            m_idEdit->clear();
+            m_nameEdit->clear();
+            m_descriptionEdit->clear();
+            m_keywordsEdit->clear();
+            m_commandEdit->clear();
+            m_argsEdit->clear();
+            m_iconEdit->clear();
+            m_workingDirectoryEdit->clear();
+            m_timeoutSpin->setValue(30000);
+            m_confirmCheck->setChecked(false);
+            m_confirmMessageEdit->clear();
+            m_detachedCheck->setChecked(false);
+            m_bestMatchCheck->setChecked(true);
+            m_loading = false;
+            return;
+        }
+
+        const QJsonObject command = m_commands.at(row);
+        m_idEdit->setText(command.value(QStringLiteral("id")).toString());
+        m_nameEdit->setText(command.value(QStringLiteral("name")).toString());
+        m_descriptionEdit->setText(command.value(QStringLiteral("description")).toString());
+        m_keywordsEdit->setPlainText(jsonArrayToStringList(command.value(QStringLiteral("keywords")).toArray()).join(QLatin1Char('\n')));
+        m_commandEdit->setText(command.value(QStringLiteral("command")).toString());
+        m_argsEdit->setPlainText(jsonArrayToStringList(command.value(QStringLiteral("args")).toArray()).join(QLatin1Char('\n')));
+        m_iconEdit->setText(command.value(QStringLiteral("icon")).toString(QStringLiteral("system-run")));
+        m_workingDirectoryEdit->setText(command.value(QStringLiteral("workingDirectory")).toString());
+        m_timeoutSpin->setValue(command.value(QStringLiteral("timeout")).toInt(30000));
+        m_confirmCheck->setChecked(command.value(QStringLiteral("confirm")).toBool(false));
+        m_confirmMessageEdit->setText(command.value(QStringLiteral("confirmMessage")).toString());
+        m_detachedCheck->setChecked(command.value(QStringLiteral("detached")).toBool(false));
+        m_bestMatchCheck->setChecked(command.value(QStringLiteral("showInBestMatch")).toBool(true));
+        m_loading = false;
+    }
+
+    void setEditorEnabled(bool enabled)
+    {
+        const QList<QWidget *> widgets {
+            m_idEdit, m_nameEdit, m_descriptionEdit, m_keywordsEdit, m_commandEdit,
+            m_argsEdit, m_iconEdit, m_workingDirectoryEdit, m_timeoutSpin,
+            m_confirmCheck, m_confirmMessageEdit, m_detachedCheck, m_bestMatchCheck
+        };
+        for (QWidget *widget : widgets) {
+            widget->setEnabled(enabled);
+        }
+        m_duplicateButton->setEnabled(enabled);
+        m_deleteButton->setEnabled(enabled);
+    }
+
+    void updateCurrentCommandFromEditor()
+    {
+        if (m_loading || m_currentRow < 0 || m_currentRow >= m_commands.size()) {
+            return;
+        }
+        QJsonObject command = m_commands.at(m_currentRow);
+        command.insert(QStringLiteral("id"), m_idEdit->text().trimmed());
+        command.insert(QStringLiteral("name"), m_nameEdit->text().trimmed());
+        command.insert(QStringLiteral("description"), m_descriptionEdit->text().trimmed());
+        command.insert(QStringLiteral("keywords"), stringListToJsonArray(plainTextToList(m_keywordsEdit)));
+        command.insert(QStringLiteral("command"), m_commandEdit->text().trimmed());
+        command.insert(QStringLiteral("args"), stringListToJsonArray(plainTextToList(m_argsEdit)));
+        command.insert(QStringLiteral("icon"), m_iconEdit->text().trimmed().isEmpty() ? QStringLiteral("system-run") : m_iconEdit->text().trimmed());
+        command.insert(QStringLiteral("workingDirectory"), m_workingDirectoryEdit->text().trimmed());
+        command.insert(QStringLiteral("timeout"), m_timeoutSpin->value());
+        command.insert(QStringLiteral("confirm"), m_confirmCheck->isChecked());
+        command.insert(QStringLiteral("confirmMessage"), m_confirmMessageEdit->text().trimmed());
+        command.insert(QStringLiteral("detached"), m_detachedCheck->isChecked());
+        command.insert(QStringLiteral("showInBestMatch"), m_bestMatchCheck->isChecked());
+        m_commands[m_currentRow] = command;
+
+        QListWidgetItem *item = m_commandList->item(m_currentRow);
+        if (item) {
+            const QString name = command.value(QStringLiteral("name")).toString();
+            const QString id = command.value(QStringLiteral("id")).toString();
+            item->setText(name.isEmpty() ? id : name);
+        }
+    }
+
+    QString uniqueId(const QString &base) const
+    {
+        QString normalized = base.trimmed().toLower();
+        normalized.replace(QLatin1Char(' '), QLatin1Char('-'));
+        if (normalized.isEmpty()) {
+            normalized = QStringLiteral("custom-command");
+        }
+
+        QStringList ids;
+        for (const QJsonObject &command : m_commands) {
+            ids << command.value(QStringLiteral("id")).toString();
+        }
+        QString candidate = normalized;
+        int index = 1;
+        while (ids.contains(candidate)) {
+            candidate = normalized + QLatin1Char('-') + QString::number(index++);
+        }
+        return candidate;
+    }
+
+    void addCommand()
+    {
+        QJsonObject command {
+            { QStringLiteral("id"), uniqueId(QStringLiteral("custom-command")) },
+            { QStringLiteral("name"), QObject::tr("New command") },
+            { QStringLiteral("description"), QString() },
+            { QStringLiteral("keywords"), QJsonArray { QObject::tr("New command") } },
+            { QStringLiteral("command"), QString() },
+            { QStringLiteral("args"), QJsonArray() },
+            { QStringLiteral("icon"), QStringLiteral("system-run") },
+            { QStringLiteral("confirm"), false },
+            { QStringLiteral("confirmMessage"), QString() },
+            { QStringLiteral("detached"), false },
+            { QStringLiteral("showInBestMatch"), true },
+            { QStringLiteral("timeout"), 30000 }
+        };
+        m_commands.append(command);
+        refreshList();
+        m_commandList->setCurrentRow(m_commands.size() - 1);
+    }
+
+    void duplicateCommand()
+    {
+        if (m_currentRow < 0 || m_currentRow >= m_commands.size()) {
+            return;
+        }
+        QJsonObject command = m_commands.at(m_currentRow);
+        const QString name = command.value(QStringLiteral("name")).toString();
+        command.insert(QStringLiteral("id"), uniqueId(command.value(QStringLiteral("id")).toString() + QStringLiteral("-copy")));
+        command.insert(QStringLiteral("name"), name + QObject::tr(" Copy"));
+        m_commands.insert(m_currentRow + 1, command);
+        refreshList();
+        m_commandList->setCurrentRow(m_currentRow + 1);
+    }
+
+    void deleteCommand()
+    {
+        if (m_currentRow < 0 || m_currentRow >= m_commands.size()) {
+            return;
+        }
+        if (QMessageBox::question(this, QObject::tr("Delete command"), QObject::tr("Delete selected command?")) != QMessageBox::Yes) {
+            return;
+        }
+        m_commands.removeAt(m_currentRow);
+        refreshList();
+    }
+
+    bool validateCommands(QString *message) const
+    {
+        QStringList ids;
+        for (int i = 0; i < m_commands.size(); ++i) {
+            const QJsonObject command = m_commands.at(i);
+            const QString id = command.value(QStringLiteral("id")).toString().trimmed();
+            const QString name = command.value(QStringLiteral("name")).toString().trimmed();
+            const QString executable = command.value(QStringLiteral("command")).toString().trimmed();
+            if (id.isEmpty() || name.isEmpty() || executable.isEmpty()) {
+                *message = QObject::tr("ID, name and command are required.");
+                return false;
+            }
+            if (ids.contains(id)) {
+                *message = QObject::tr("Command IDs must be unique.");
+                return false;
+            }
+            ids << id;
+        }
+        return true;
+    }
+
+    void saveAndAccept()
+    {
+        updateCurrentCommandFromEditor();
+        QString message;
+        if (!validateCommands(&message)) {
+            QMessageBox::warning(this, QObject::tr("Custom commands"), message);
+            return;
+        }
+
+        QJsonArray commands;
+        for (const QJsonObject &command : m_commands) {
+            commands.append(command);
+        }
+        m_root.insert(QStringLiteral("version"), m_root.value(QStringLiteral("version")).toInt(1));
+        m_root.insert(QStringLiteral("commands"), commands);
+
+        const QString path = commandConfigPath();
+        QDir dir(QFileInfo(path).absolutePath());
+        if (!dir.exists() && !dir.mkpath(QStringLiteral("."))) {
+            QMessageBox::warning(this, QObject::tr("Custom commands"), QObject::tr("Failed to create configuration directory."));
+            return;
+        }
+
+        QSaveFile file(path);
+        if (!file.open(QIODevice::WriteOnly | QIODevice::Text)) {
+            QMessageBox::warning(this, QObject::tr("Custom commands"), QObject::tr("Failed to write command configuration."));
+            return;
+        }
+        file.write(QJsonDocument(m_root).toJson(QJsonDocument::Indented));
+        if (!file.commit()) {
+            QMessageBox::warning(this, QObject::tr("Custom commands"), QObject::tr("Failed to save command configuration."));
+            return;
+        }
+        accept();
+    }
+
+    QJsonObject m_root;
+    QVector<QJsonObject> m_commands;
+    int m_currentRow = -1;
+    bool m_loading = false;
+
+    QListWidget *m_commandList = nullptr;
+    QPushButton *m_addButton = nullptr;
+    QPushButton *m_duplicateButton = nullptr;
+    QPushButton *m_deleteButton = nullptr;
+    QLineEdit *m_idEdit = nullptr;
+    QLineEdit *m_nameEdit = nullptr;
+    QLineEdit *m_descriptionEdit = nullptr;
+    QPlainTextEdit *m_keywordsEdit = nullptr;
+    QLineEdit *m_commandEdit = nullptr;
+    QPlainTextEdit *m_argsEdit = nullptr;
+    QLineEdit *m_iconEdit = nullptr;
+    QLineEdit *m_workingDirectoryEdit = nullptr;
+    QSpinBox *m_timeoutSpin = nullptr;
+    QCheckBox *m_confirmCheck = nullptr;
+    QLineEdit *m_confirmMessageEdit = nullptr;
+    QCheckBox *m_detachedCheck = nullptr;
+    QCheckBox *m_bestMatchCheck = nullptr;
+    QLabel *m_pathLabel = nullptr;
+    QDialogButtonBox *m_buttonBox = nullptr;
+};
