+void ResultArea::pressTab()
+{
+    if (!m_isSelected) {
+        return;
+    }
+
+    auto toggleBestListIfNeeded = [this]() -> bool {
+        if (m_bestListWidget->getResultNum() <= NUM_LIMIT_SHOWN_DEFAULT) {
+            return false;
+        }
+
+        QModelIndex index = m_bestListWidget->getCurrentSelection();
+        if (m_bestListWidget->getExpandState()) {
+            int row = index.isValid() ? index.row() : 0;
+            int targetRow = row < NUM_LIMIT_SHOWN_DEFAULT ? row : NUM_LIMIT_SHOWN_DEFAULT - 1;
+            m_bestListWidget->reduceListSlot();
+            QModelIndex targetIndex = m_bestListWidget->getModlIndex(targetRow, 0);
+            m_bestListWidget->setResultSelection(targetIndex);
+            m_selectedPluginID = m_bestListWidget->getWidgetName();
+            sendKeyPressSignal(m_selectedPluginID);
+            return true;
+        }
+
+        m_bestListWidget->expandListSlot();
+        int targetRow = index.isValid() ? index.row() : 0;
+        QModelIndex targetIndex = m_bestListWidget->getModlIndex(targetRow, 0);
+        m_bestListWidget->setResultSelection(targetIndex);
+        m_selectedPluginID = m_bestListWidget->getWidgetName();
+        sendKeyPressSignal(m_selectedPluginID);
+        return true;
+    };
+
+    auto toggleResultWidgetIfNeeded = [this](ResultWidget *plugin) -> bool {
+        if (plugin->getResultNum() <= NUM_LIMIT_SHOWN_DEFAULT) {
+            return false;
+        }
+
+        QModelIndex index = plugin->getCurrentSelection();
+        if (plugin->getExpandState()) {
+            int row = index.isValid() ? index.row() : 0;
+            int targetRow = row < NUM_LIMIT_SHOWN_DEFAULT ? row : NUM_LIMIT_SHOWN_DEFAULT - 1;
+            plugin->reduceListSlot();
+            QModelIndex targetIndex = plugin->getModlIndex(targetRow, 0);
+            plugin->setResultSelection(targetIndex);
+            m_selectedPluginID = plugin->pluginId();
+            sendKeyPressSignal(m_selectedPluginID);
+            return true;
+        }
+
+        plugin->expandListSlot();
+        int targetRow = index.isValid() ? index.row() : 0;
+        QModelIndex targetIndex = plugin->getModlIndex(targetRow, 0);
+        plugin->setResultSelection(targetIndex);
+        m_selectedPluginID = plugin->pluginId();
+        sendKeyPressSignal(m_selectedPluginID);
+        return true;
+    };
+
+    if (m_selectedPluginID == m_bestListWidget->getWidgetName()) {
+        toggleBestListIfNeeded();
+        return;
+    }
+
+    for (ResultWidget *plugin : m_widgetList) {
+        if (m_selectedPluginID == plugin->pluginId()) {
+            toggleResultWidgetIfNeeded(plugin);
+            return;
+        }
+    }
+}
