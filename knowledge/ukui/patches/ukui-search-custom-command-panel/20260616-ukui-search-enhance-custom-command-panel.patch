+void MainWindow::closeSearchSession()
+{
+    qDebug()<<"Mainwindow search session will be closed";
+
+    if (QWidget *modal = QApplication::activeModalWidget()) {
+        if (isSearchOwnedWindow(modal)) {
+            qDebug()<<"Close owned modal widget before closing search session" << modal;
+            modal->close();
+            modal->hide();
         }
-        return true;
-    } else {
-        //有上层弹窗未关闭，不允许隐藏主界面
-        qWarning()<<"There is a dialog onside, so that mainwindow can not be hidden.";
-        return false;
+    }
+
+    const auto widgets = QApplication::topLevelWidgets();
+    for (QWidget *widget : widgets) {
+        if (widget && widget != this && widget->isVisible() && widget->isModal() && isSearchOwnedWindow(widget)) {
+            qDebug()<<"Close owned modal widget before closing search session" << widget;
+            widget->close();
+            widget->hide();
+        }
+    }
+
+    if (m_askDialog && m_askDialog->isVisible()) {
+        m_askDialog->close();
+        m_askDialog->hide();
+    }
+    m_isAskDialogVisible = false;
+    m_currentSearchAsked = false;
+    m_askTimer->stop();
+    m_researchTimer->stop();
+    Q_EMIT m_searchResultPage->stopSearch();
+    m_searchResultPage->hide();
+    resizeHeight(68);
+    tryMoveUp2Panel(68);
+    this->clearSearchResult();
+    QGuiApplication::inputMethod()->hide();
+    this->hide();
+
+    if(!m_releaseFreeMemoryTimerWorking) {
+        m_releaseFreeMemoryTimerWorking = true;
+        QTimer::singleShot(2000, this, [&](){
+            if(!this->isVisible()) {
+                MallocExtension::instance()->ReleaseFreeMemory();
+            }
+            m_releaseFreeMemoryTimerWorking = false;
+        });
     }
 }
 
+bool MainWindow::isSearchOwnedWindow(QWidget *window) const
+{
+    QWidget *widget = window;
+    while (widget) {
+        if (widget == this || widget == m_askDialog) {
+            return true;
+        }
+        widget = widget->parentWidget();
+    }
+    return false;
+}
