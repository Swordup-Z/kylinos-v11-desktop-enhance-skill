+class CommandConfirmDialog : public QDialog
+{
+public:
+    CommandConfirmDialog(const QString &title, const QString &message, QWidget *parent = nullptr)
+        : QDialog(parent)
+    {
+        setWindowTitle(title);
+        setModal(true);
+
+        auto *layout = new QVBoxLayout(this);
+        layout->setContentsMargins(24, 20, 24, 20);
+        layout->setSpacing(18);
+
+        auto *messageLabel = new QLabel(message, this);
+        messageLabel->setWordWrap(true);
+        messageLabel->setTextInteractionFlags(Qt::TextSelectableByMouse);
+        layout->addWidget(messageLabel);
+
+        auto *buttonLayout = new QHBoxLayout();
+        buttonLayout->addStretch();
+        m_cancelButton = new QPushButton(CommandSearchPlugin::tr("Cancel"), this);
+        m_runButton = new QPushButton(CommandSearchPlugin::tr("Run"), this);
+        buttonLayout->addWidget(m_cancelButton);
+        buttonLayout->addWidget(m_runButton);
+        layout->addLayout(buttonLayout);
+
+        const QString buttonStyle = QStringLiteral(
+            "QPushButton { min-width: 88px; padding: 6px 14px; }"
+            "QPushButton:focus { border: 2px solid palette(highlight); }");
+        m_cancelButton->setStyleSheet(buttonStyle);
+        m_runButton->setStyleSheet(buttonStyle);
+        m_cancelButton->setFocusPolicy(Qt::StrongFocus);
+        m_runButton->setFocusPolicy(Qt::StrongFocus);
+        m_cancelButton->setAutoDefault(false);
+        m_runButton->setAutoDefault(false);
+        m_cancelButton->setDefault(false);
+        m_runButton->setDefault(false);
+
+        connect(m_cancelButton, &QPushButton::clicked, this, &QDialog::reject);
+        connect(m_runButton, &QPushButton::clicked, this, &QDialog::accept);
+
+        m_guardTimer.start();
+        QTimer::singleShot(0, this, [this]() {
+            m_cancelButton->setFocus(Qt::OtherFocusReason);
+        });
+    }
+
+    QPushButton *cancelButton() const
+    {
+        return m_cancelButton;
+    }
+
+    QPushButton *runButton() const
+    {
+        return m_runButton;
+    }
+
+protected:
+    void keyPressEvent(QKeyEvent *event) override
+    {
+        if ((event->key() == Qt::Key_Return || event->key() == Qt::Key_Enter || event->key() == Qt::Key_Space)
+            && m_guardTimer.elapsed() < 250) {
+            event->accept();
+            return;
+        }
+
+        if (event->key() == Qt::Key_Left || event->key() == Qt::Key_Right) {
+            focusNextButton();
+            event->accept();
+            return;
+        }
+
+        if (event->key() == Qt::Key_Return || event->key() == Qt::Key_Enter) {
+            if (focusWidget() == m_runButton) {
+                accept();
+            } else {
+                reject();
+            }
+            event->accept();
+            return;
+        }
+
+        if (event->key() == Qt::Key_Escape) {
+            reject();
+            event->accept();
+            return;
+        }
+
+        QDialog::keyPressEvent(event);
+    }
+
+private:
+    void focusNextButton()
+    {
+        if (focusWidget() == m_cancelButton) {
+            m_runButton->setFocus(Qt::TabFocusReason);
+        } else {
+            m_cancelButton->setFocus(Qt::TabFocusReason);
+        }
+    }
+
+    QPushButton *m_cancelButton = nullptr;
+    QPushButton *m_runButton = nullptr;
+    QElapsedTimer m_guardTimer;
+};
+
+class CommandOutputDialog : public QDialog
+{
+public:
+    CommandOutputDialog(const QString &title, QWidget *parent = nullptr)
+        : QDialog(parent)
+    {
+        setWindowTitle(title);
+        resize(720, 480);
+        setModal(false);
+
+        auto *layout = new QVBoxLayout(this);
+        layout->setContentsMargins(16, 16, 16, 16);
+        layout->setSpacing(12);
+
+        m_statusLabel = new QLabel(CommandSearchPlugin::tr("Running..."), this);
+        layout->addWidget(m_statusLabel);
+
+        m_outputEdit = new QPlainTextEdit(this);
+        m_outputEdit->setReadOnly(true);
+        m_outputEdit->setLineWrapMode(QPlainTextEdit::NoWrap);
+        layout->addWidget(m_outputEdit, 1);
+
+        auto *buttonLayout = new QHBoxLayout();
+        buttonLayout->addStretch();
+        m_closeButton = new QPushButton(CommandSearchPlugin::tr("Close"), this);
+        m_closeButton->setEnabled(false);
+        buttonLayout->addWidget(m_closeButton);
+        layout->addLayout(buttonLayout);
+
+        connect(m_closeButton, &QPushButton::clicked, this, &QDialog::accept);
+    }
+
+    int run(const QString &command, const QStringList &args, const QString &workingDirectory, int timeout)
+    {
+        QProcess process;
+        if (!workingDirectory.isEmpty()) {
+            process.setWorkingDirectory(workingDirectory);
+        }
+
+        QTimer timer;
+        timer.setSingleShot(true);
+
+        connect(&process, &QProcess::readyReadStandardOutput, this, [&]() {
+            appendText(QString::fromLocal8Bit(process.readAllStandardOutput()));
+        });
+        connect(&process, &QProcess::readyReadStandardError, this, [&]() {
+            appendText(QString::fromLocal8Bit(process.readAllStandardError()));
+        });
+        connect(&timer, &QTimer::timeout, this, [&]() {
+            m_timedOut = true;
+            process.kill();
+        });
+        connect(&process,
+                QOverload<int, QProcess::ExitStatus>::of(&QProcess::finished),
+                this,
+                [&](int exitCode, QProcess::ExitStatus exitStatus) {
+                    appendText(QString::fromLocal8Bit(process.readAllStandardOutput()));
+                    appendText(QString::fromLocal8Bit(process.readAllStandardError()));
+                    timer.stop();
+                    m_exitCode = exitCode;
+                    m_exitStatus = exitStatus;
+                    if (m_timedOut) {
+                        m_statusLabel->setText(CommandSearchPlugin::tr("Command timed out."));
+                    } else if (exitStatus != QProcess::NormalExit || exitCode != 0) {
+                        m_statusLabel->setText(CommandSearchPlugin::tr("Command failed."));
+                    } else {
+                        m_statusLabel->setText(CommandSearchPlugin::tr("Command completed successfully."));
+                    }
+                    m_running = false;
+                    m_closeButton->setEnabled(true);
+                    m_closeButton->setFocus(Qt::OtherFocusReason);
+                });
+        connect(&process, &QProcess::errorOccurred, this, [&](QProcess::ProcessError error) {
+            if (error == QProcess::FailedToStart) {
+                m_statusLabel->setText(CommandSearchPlugin::tr("Failed to start command."));
+                m_running = false;
+                m_closeButton->setEnabled(true);
+                m_closeButton->setFocus(Qt::OtherFocusReason);
+            }
+        });
+
+        process.start(command, args);
+        if (!process.waitForStarted(5000)) {
+            m_statusLabel->setText(CommandSearchPlugin::tr("Failed to start command."));
+            m_running = false;
+            m_closeButton->setEnabled(true);
+            m_closeButton->setFocus(Qt::OtherFocusReason);
+            exec();
+            return -1;
+        }
+
+        timer.start(timeout > 0 ? timeout : 30000);
+        exec();
+        return m_timedOut || m_exitStatus != QProcess::NormalExit ? -1 : m_exitCode;
+    }
+
+protected:
+    void closeEvent(QCloseEvent *event) override
+    {
+        if (m_running) {
+            event->ignore();
+            return;
+        }
+        QDialog::closeEvent(event);
+    }
+
+private:
+    void appendText(const QString &text)
+    {
+        if (text.isEmpty()) {
+            return;
+        }
+        m_outputEdit->moveCursor(QTextCursor::End);
+        m_outputEdit->insertPlainText(text);
+        m_outputEdit->moveCursor(QTextCursor::End);
+    }
+
+    QLabel *m_statusLabel = nullptr;
+    QPlainTextEdit *m_outputEdit = nullptr;
+    QPushButton *m_closeButton = nullptr;
+    bool m_running = true;
+    bool m_timedOut = false;
+    int m_exitCode = -1;
+    QProcess::ExitStatus m_exitStatus = QProcess::CrashExit;
+};
