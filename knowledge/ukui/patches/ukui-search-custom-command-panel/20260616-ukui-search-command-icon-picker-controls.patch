-        m_iconPreview->setFixedSize(32, 32);
-        m_iconPreview->setAlignment(Qt::AlignCenter);
-        m_iconPreview->setStyleSheet(QStringLiteral(
-            "background-color: transparent;"
-            "border: 0;"
-        ));
         m_iconEdit = new QComboBox(iconWidget);
         m_iconEdit->setEditable(true);
         m_iconEdit->setInsertPolicy(QComboBox::NoInsert);
@@ -263,11 +242,14 @@ private:
             m_iconEdit->addItem(themedIcon(name), name);
         }
         m_iconEdit->setMaxVisibleItems(18);
+        m_iconDropdownButton = new QPushButton(QStringLiteral("▼"), iconWidget);
+        m_iconDropdownButton->setFixedWidth(36);
+        m_iconDropdownButton->setSizePolicy(QSizePolicy::Fixed, QSizePolicy::Fixed);
         m_browseIconButton = new QPushButton(QStringLiteral("选择..."), iconWidget);
         m_browseIconButton->setSizePolicy(QSizePolicy::Fixed, QSizePolicy::Fixed);
         iconLayout->addWidget(m_iconEdit);
+        iconLayout->addWidget(m_iconDropdownButton);
         iconLayout->addWidget(m_browseIconButton);
-        iconLayout->addWidget(m_iconPreview);
         m_workingDirectoryEdit = new QLineEdit(editorPage);
         m_timeoutSpin = new QSpinBox(editorPage);
         m_timeoutSpin->setRange(1000, 600000);
@@ -328,6 +310,9 @@ private:
         connect(m_saveCurrentButton, &QPushButton::clicked, this, [this]() {
             saveCurrentCommand();
         });
+        connect(m_iconDropdownButton, &QPushButton::clicked, this, [this]() {
+            m_iconEdit->showPopup();
+        });
         connect(m_browseIconButton, &QPushButton::clicked, this, [this]() {
             chooseIconFile();
         });
@@ -351,7 +336,6 @@ private:
         connect(m_commandEdit, &QLineEdit::textChanged, this, changed);
         connect(m_argsEdit, &QPlainTextEdit::textChanged, this, changed);
         connect(m_iconEdit->lineEdit(), &QLineEdit::textChanged, this, [this, changed]() {
-            updateIconPreview();
             changed();
         });
         connect(m_workingDirectoryEdit, &QLineEdit::textChanged, this, changed);
@@ -475,7 +459,7 @@ private:
     {
         const QList<QWidget *> widgets {
             m_idEdit, m_nameEdit, m_descriptionEdit, m_keywordsEdit, m_commandEdit,
-            m_argsEdit, m_iconEdit, m_browseIconButton, m_workingDirectoryEdit, m_timeoutSpin,
+            m_argsEdit, m_iconEdit, m_iconDropdownButton, m_browseIconButton, m_workingDirectoryEdit, m_timeoutSpin,
             m_confirmCheck, m_confirmMessageEdit, m_detachedCheck, m_bestMatchCheck
         };
         for (QWidget *widget : widgets) {
@@ -501,12 +485,6 @@ private:
         }
         m_iconEdit->setCurrentIndex(index);
         m_iconEdit->setEditText(normalized);
-        updateIconPreview();
-    }
-
-    void updateIconPreview()
-    {
-        m_iconPreview->setPixmap(iconBadgePixmap(themedIcon(iconName()), QSize(32, 32)));
     }
 
     void updateCurrentCommandFromEditor()
@@ -694,8 +672,8 @@ private:
     QLineEdit *m_commandEdit = nullptr;
     QPlainTextEdit *m_argsEdit = nullptr;
     QComboBox *m_iconEdit = nullptr;
+    QPushButton *m_iconDropdownButton = nullptr;
     QPushButton *m_browseIconButton = nullptr;
-    QLabel *m_iconPreview = nullptr;
     QLineEdit *m_workingDirectoryEdit = nullptr;
     QSpinBox *m_timeoutSpin = nullptr;
     QCheckBox *m_confirmCheck = nullptr;
