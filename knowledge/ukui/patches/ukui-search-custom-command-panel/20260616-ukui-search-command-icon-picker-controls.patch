 search-ukcc-plugin/search.cpp | 54 +++++++++++------------------------
 1 file changed, 16 insertions(+), 38 deletions(-)

diff --git a/search-ukcc-plugin/search.cpp b/search-ukcc-plugin/search.cpp
index e05b7f6f..3fbc2a8b 100644
--- a/search-ukcc-plugin/search.cpp
+++ b/search-ukcc-plugin/search.cpp
@@ -36,7 +36,6 @@
 #include <QLabel>
 #include <QLineEdit>
 #include <QListWidget>
-#include <QPainter>
 #include <QPlainTextEdit>
 #include <QString>
 #include <QProcess>
@@ -135,24 +134,6 @@ QIcon themedIcon(const QString &name)
     return QIcon::fromTheme(trimmed, QIcon::fromTheme(QStringLiteral("system-run")));
 }
 
-QPixmap iconBadgePixmap(const QIcon &icon, const QSize &size)
-{
-    QPixmap pixmap(size);
-    pixmap.fill(Qt::transparent);
-
-    QPainter painter(&pixmap);
-    painter.setRenderHint(QPainter::Antialiasing, true);
-    const QRect outer(QPoint(0, 0), size);
-    const QRect badge = outer.adjusted(1, 1, -1, -1);
-    painter.setPen(QColor(QStringLiteral("#566176")));
-    painter.setBrush(QColor(QStringLiteral("#2f3747")));
-    painter.drawRoundedRect(badge, 4, 4);
-
-    const QRect iconRect = badge.adjusted(5, 5, -5, -5);
-    icon.paint(&painter, iconRect, Qt::AlignCenter, QIcon::Selected, QIcon::On);
-    return pixmap;
-}
-
 class CommandConfigDialog : public QDialog
 {
 public:
@@ -194,8 +175,13 @@ private:
             "}"
             "QPlainTextEdit { padding: 6px; }"
             "QComboBox::drop-down {"
-            "  width: 34px;"
-            "  border-left: 1px solid palette(mid);"
+            "  width: 0px;"
+            "  border: 0px;"
+            "}"
+            "QComboBox::down-arrow {"
+            "  image: none;"
+            "  width: 0px;"
+            "  height: 0px;"
             "}"
         ));
 
@@ -235,13 +221,6 @@ private:
         auto *iconLayout = new QHBoxLayout(iconWidget);
         iconLayout->setContentsMargins(0, 0, 0, 0);
         iconLayout->setSpacing(8);
