+QStringList availableIconNames()
+{
+    QSet<QString> names;
+    QStringList roots = QIcon::themeSearchPaths();
+    roots << QStringLiteral("/usr/share/icons")
+          << QDir::homePath() + QStringLiteral("/.local/share/icons");
+    roots.removeDuplicates();
+
+    const QStringList suffixes {
+        QStringLiteral("*.png"),
+        QStringLiteral("*.svg"),
+        QStringLiteral("*.xpm")
+    };
+    for (const QString &root : roots) {
+        if (!QDir(root).exists()) {
+            continue;
+        }
+        QDirIterator iterator(root, suffixes, QDir::Files, QDirIterator::Subdirectories);
+        while (iterator.hasNext()) {
+            iterator.next();
+            const QString name = QFileInfo(iterator.filePath()).completeBaseName().trimmed();
+            if (!name.isEmpty()) {
+                names.insert(name);
+            }
+        }
+    }
+
+    QStringList sorted = names.values();
+    sorted.sort(Qt::CaseInsensitive);
+    return sorted;
+}
+
+QIcon themedIcon(const QString &name)
+{
+    const QString trimmed = name.trimmed();
+    return QIcon::fromTheme(trimmed, QIcon::fromTheme(QStringLiteral("system-run")));
+}
