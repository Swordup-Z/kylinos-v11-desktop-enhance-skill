+bool isReasonableIconName(const QString &name)
+{
+    if (name.size() < 2 || name.size() > 96) {
+        return false;
+    }
+    bool onlyDigits = true;
+    for (const QChar &ch : name) {
+        if (!ch.isDigit()) {
+            onlyDigits = false;
+            break;
+        }
+    }
+    return !onlyDigits;
+}
